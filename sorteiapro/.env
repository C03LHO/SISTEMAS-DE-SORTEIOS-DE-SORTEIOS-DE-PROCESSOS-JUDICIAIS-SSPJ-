# ─────────────────────────────────────────────────────────────────────────────
# SorteiaPro — Configuração para desenvolvimento local com SQLite
# Copie este arquivo para .env e ajuste conforme necessário
# Para produção, mude DATABASE_URL para PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados: SQLite (arquivo local, sem instalação necessária)
DATABASE_URL=sqlite+aiosqlite:///./sorteiapro.db
SYNC_DATABASE_URL=sqlite:///./sorteiapro.db

# Segurança: troque esta chave em produção!
SECRET_KEY=sorteiapro-dev-secret-key-troque-em-producao-2025

# JWT: 8 horas de validade
ACCESS_TOKEN_EXPIRE_HOURS=8

# Diretório para uploads de documentos de conflito
UPLOAD_DIR=./uploads

# Ambiente (development = SQL echo ligado no console)
ENVIRONMENT=development
