# Banco de dados (async para a aplicação, sync para o Alembic)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sorteiapro
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/sorteiapro

# Segurança JWT
SECRET_KEY=troque-esta-chave-segura-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# Uploads de documentos de conflito
UPLOAD_DIR=./uploads

# Ambiente de execução
ENVIRONMENT=development
